# ============================================================
# Complya — Web (Next.js) Environment Variables
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# ^ URL de l'API NestJS — utilisée par le SDK client

NODE_ENV=development

# ------------------------------------------------------------
# AUTHENTIFICATION — Clerk (Next.js)
# Récupérer sur : dashboard.clerk.com → votre app → API Keys
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Clé publique — préfixe NEXT_PUBLIC_ = exposée côté client (prévu par Clerk)

CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Clé secrète — utilisée côté serveur uniquement (Server Actions, middleware)
# NE JAMAIS exposer cette clé côté client

# Routes Clerk — personnalisables
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ------------------------------------------------------------
# FEATURE FLAGS
# Désactiver des modules par environnement (false = module invisible)
# ------------------------------------------------------------
NEXT_PUBLIC_ENABLE_OCR=false
# ^ Activer le module OCR (false jusqu'à l'Alpha A13)

NEXT_PUBLIC_ENABLE_RECONCILIATION=false
# ^ Activer le rapprochement bancaire (false jusqu'à l'Alpha A18)

NEXT_PUBLIC_ENABLE_MULTI_COUNTRY=false
# ^ Activer le moteur multi-pays CEMAC (false jusqu'à v2.0)
