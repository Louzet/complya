{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    // Cache incrémental hors de outDir (dist) : tsc --noEmit ne touche jamais dist,
    // donc le type-check est immunisé contre les droits/propriété de dist.
    "tsBuildInfoFile": "./node_modules/.cache/tsc/api.tsbuildinfo",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
