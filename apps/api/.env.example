# ============================================================
# CEMAC Compliance Platform — API Environment Variables
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NODE_ENV=development                        # development | staging | production
PORT=3001                                   # Port d'écoute NestJS
API_URL=http://localhost:3001               # URL publique de l'API (CORS, liens emails)

# ------------------------------------------------------------
# BASE DE DONNÉES — Neon PostgreSQL
# Récupérer sur : console.neon.tech → votre projet → Connection string
# IMPORTANT : deux URLs différentes selon l'usage
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/cemac?sslmode=require&pgbouncer=true
# ^ Connexion POOLÉE via PgBouncer — à utiliser pour Prisma en runtime (app)

DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/cemac?sslmode=require
# ^ Connexion DIRECTE — obligatoire pour prisma migrate et prisma db push

# Pour le dev local avec Docker (postgres container) :
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cemac_dev
# DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@postgres:5432/cemac_dev

# ------------------------------------------------------------
# AUTHENTIFICATION — Clerk
# Récupérer sur : dashboard.clerk.com → votre app → API Keys
# ------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Clé secrète backend — NE JAMAIS exposer côté client

CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Référence uniquement — la vérification JWT se fait avec CLERK_SECRET_KEY

CLERK_JWT_KEY=
# ^ Optionnel : clé publique JWT pour vérification offline (format PEM)

# ------------------------------------------------------------
# STOCKAGE OBJET — Cloudflare R2
# Récupérer sur : dash.cloudflare.com → R2 → votre bucket → API tokens
# ------------------------------------------------------------
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ^ Cloudflare Account ID (visible dans le dashboard URL)

R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ^ Clé d'accès R2 (Manage R2 API tokens → Create API token → Object Read & Write)

R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ^ Clé secrète R2

R2_BUCKET_NAME=cemac-documents-dev
# ^ Nom du bucket — créer un bucket séparé par env : -dev, -staging, -prod

R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# ^ URL publique si le bucket est public (optionnel — assets non sensibles uniquement)

R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
# ^ Endpoint S3-compatible : https://<ACCOUNT_ID>.r2.cloudflarestorage.com

SIGNED_URL_EXPIRY_SECONDS=900
# ^ Durée de validité des signed URLs en secondes (défaut : 15 min)

# ------------------------------------------------------------
# JOBS ASYNCHRONES — Trigger.dev
# Récupérer sur : app.trigger.dev → votre projet → API Keys
# ------------------------------------------------------------
TRIGGER_SECRET_KEY=tr_dev_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Clé secrète Trigger.dev (préfixe tr_dev_ en dev, tr_prod_ en prod)

TRIGGER_API_URL=https://api.trigger.dev
# ^ URL de l'API Trigger.dev (ne pas changer sauf self-hosted)

# ------------------------------------------------------------
# EMAIL — Resend (recommandé)
# Alternatives : SendGrid, SMTP
# Récupérer sur : resend.com → API Keys
# ------------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ^ Laisser vide en dev pour désactiver l'envoi d'emails

EMAIL_FROM=noreply@votredomaine.com
# ^ Adresse expéditrice (domaine vérifié sur Resend)

# ------------------------------------------------------------
# SÉCURITÉ & CORS
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# ^ URLs autorisées pour CORS (séparées par virgule, sans espace)
# En prod : https://app.votredomaine.com

JWT_ALGORITHM=RS256
# ^ Algorithme JWT utilisé par Clerk (ne pas changer)

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
THROTTLE_TTL=60000
# ^ Fenêtre de temps en ms (défaut : 1 minute = 60000ms)

THROTTLE_LIMIT=100
# ^ Nombre de requêtes max par fenêtre par IP

# ------------------------------------------------------------
# LOGS & MONITORING
# ------------------------------------------------------------
LOG_LEVEL=debug
# ^ debug | info | warn | error (debug en dev, info en prod)

SENTRY_DSN=
# ^ Optionnel : DSN Sentry pour monitoring d'erreurs en prod
# Récupérer sur : sentry.io → votre projet → Settings → SDK Setup

# ------------------------------------------------------------
# DÉVELOPPEMENT UNIQUEMENT
# Variables ci-dessous ignorées si NODE_ENV !== 'development'
# ------------------------------------------------------------
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/cemac_dev
# ^ Connexion vers le postgres Docker local (dev uniquement, sans Docker Compose)
