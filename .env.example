# ============================================================
# Complya — Variables racine (Turborepo / CI/CD)
# Copier ce fichier en .env si nécessaire
# NE JAMAIS committer les fichiers .env réels
# ============================================================

# Environnement cible pour le build
NODE_ENV=development

# Registry Docker (pour le CI/CD)
DOCKER_REGISTRY=ghcr.io/votre-org/complya

# Tag de l'image Docker (généré automatiquement en CI via SHA)
DOCKER_TAG=latest

# UID/GID du développeur host — fichiers créés dans les containers seront lisibles sans sudo
# Récupérer avec : id -u  et  id -g
UID=1000
GID=1000
